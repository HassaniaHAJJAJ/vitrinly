# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, used for checkout/order creation. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# PayPal (developer.paypal.com app credentials, used for the Smart Button
# and to create/capture orders server-side). Use the sandbox app while
# testing; PAYPAL_API_BASE defaults to the sandbox API if unset.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Stripe Connect (dashboard.stripe.com/test/apikeys for the test/sandbox key).
# Used for Stripe Express onboarding and Checkout Sessions.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Base URL used in emails, PayPal redirects, and Stripe onboarding return URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
